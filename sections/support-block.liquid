{{ 'section-support-block.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="{{ 'component-slider.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'component-slider.css' | asset_url | stylesheet_tag }}</noscript>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
   .section-{{ section.id }} .support-block-card .support-block-card__image-wrapper{
/*       width: {{ section.settings.icon_outer_size }}px; */
      height: {{ section.settings.icon_outer_size }}px;
      border-radius:{{ section.settings.image_radius }};
    }

   .section-{{ section.id }} .support-block-card .support-block-card__image-wrapper img{
    border-radius:{{ section.settings.image_radius }};
  }
  
   .section-{{ section.id }} .support-block-card .support-block-card__image-wrapper img{
       width: auto;     width: 40px;
      height: {{ section.settings.icon_size }}px;
      object-fit: contain;   
   }
   .support-block-list__item.list__item .support-block-card .support-block-card__info{
     width:calc( 100% - {{ section.settings.icon_outer_size }}px );
   }
  {%- for block in section.blocks -%}
  .section-{{ section.id }}.about-support-block.support-block  #Slide-{{ section.id }}-{{ forloop.index }} .support-block-card .support-block-card__image-wrapper:before{content:'';mask-image:url('{{block.settings.image | image_url: width: 275 }}');-webkit-mask-image:url('{{block.settings.image | image_url: width: 275 }}');background:var(--gradient-base-accent-1); width: 80px;
     height: 80px;-webkit-mask-position: center; transition:all 0.3s linear;
    -webkit-mask-repeat: no-repeat;-webkit-mask-size: contain;}
  .section-{{ section.id }}.about-support-block.support-block  #Slide-{{ section.id }}-{{ forloop.index }} .support-block-card .support-block-card__image-wrapper img{display:none;}
  .section-{{ section.id }}.about-support-block.support-block  #Slide-{{ section.id }}-{{ forloop.index }} .support-block-card:hover .support-block-card__image-wrapper:before{background: var(--gradient-base-background-2);}  
    {%- endfor -%}
  .support-block{position:relative;}
  {% if section.settings.bg_image %}
   .section-{{ section.id }}.support-block:before{content:'';width:100%;height:100%;background-image:url('{{ section.settings.bg_image | image_url: width: 1920 }}');position:absolute;background-repeat: no-repeat;background-size: cover;}
   .section-{{ section.id }}.support-block.about-support-block:after{content:'';width:100%;height:100%;background:rgba(var(--color-base-background-2),0.7);position:absolute;top:0;}
    {% endif  %}
   {% if section.settings.sec_image_01 != blank %}
     .about-support-block.support-block .row{display: grid; justify-content: space-between;grid-template-columns: 1fr 1fr;grid-gap: 200px;}
     @media screen and (max-width: 1650px) {
       .about-support-block.support-block .row{grid-gap:100px;}
     }
     @media screen and (max-width: 1540px) {
       .about-support-block.support-block .row{grid-gap:50px;}
     }
   {% endif  %}
   .about-support-block.support-block .support-block-list__item{background: var(--gradient-base-background-1);height: 100%;}
   .about-support-block.support-block .support-block-list__item.grid__item .support-block-card__info{padding-top: 2rem;}
   .about-support-block.support-block .support-block-list__item.grid__item .support-block-card__info h3{ color: var(--gradient-base-accent-1);font-size:18px;font-weight:500;}   
   .about-support-block.support-block .image-wrapper .images{
     width: auto;
    display: flex;
    flex-direction: column;
    position: relative;
   }
    .about-support-block.support-block .image-wrapper .images img:last-child{ 
    transform: translate(300px, -60px);
   -webkit-transform: translate(300px, -60px);
    position: absolute;
    right: 0;
    bottom: 0;}
  .about-support-block.support-block .image-wrapper{display:flex;margin-top: 80px;}
  .about-support-block.support-block .text-wrapper a{    
    text-decoration: none;
    font-size: 24px;
    font-weight: 700;}
  .about-support-block.support-block .text-wrapper a:hover{color:var(--gradient-base-accent-1);}
  .about-support-block.support-block .text-wrapper h6{font-size: 18px;font-weight:500;margin:0; }
  .about-support-block.support-block .text-wrapper{margin-left:50px;transform: translateY(40px);-webkit-transform: translateY(40px);}
  .about-support-block.support-block .title {margin: 0 0 30px 0;}
  .about-support-block.support-block .support-block-list{grid-gap:20px;}
  @media screen and (max-width: 1540px) {
     .about-support-block.support-block .text-wrapper a{font-size:20px;}
  }
  @media screen and (max-width: 1439px) and (min-width:1200px){
     .about-support-block.support-block .text-wrapper a{font-size:14px;}
  }
  @media screen and (max-width: 1439px) {
  .about-support-block .support-block-list__item .support-block-card{padding:2rem}
  .about-support-block.support-block .row {grid-gap: 30px;}  
  .about-support-block.support-block .text-wrapper{margin-left: 30px;}
  .about-support-block.support-block .image-wrapper .images img:last-child{-webkit-transform: translate(200px, -100px);transform: translate(200px, -100px);}  
  }
   @media screen and (max-width: 1199px) {
  .about-support-block.support-block .row{grid-template-columns: 1fr;}
  .about-support-block.support-block .text-wrapper {
    margin-left: 30px;
    transform: translate(260px, 0px);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
}
     .about-support-block.support-block .image-wrapper .images img:last-child{transform: translate(200px, 40px);-webkit-transform: translate(200px, 40px);}
    .about-support-block.support-block .support-block-list__item{
      width: calc(33.33% - var(--grid-desktop-horizontal-spacing) * 1 / 2);
      max-width: calc(33.33% - var(--grid-desktop-horizontal-spacing) * 1 / 3);}
   }
   @media screen and (max-width: 990px) {
     .about-support-block.support-block .text-wrapper{transform: translate(155px, 0px);-webkit-transform: translate(155px, 0px);}
     .about-support-block.support-block .image-wrapper .images img:last-child{-webkit-transform: translate(165px, 40px);transform: translate(165px, 40px);}
     .about-support-block.support-block .text-wrapper a {font-size: 18px;}
   }
  @media screen and (max-width: 767px) {
    .about-support-block.support-block .text-wrapper{-webkit-transform: translate(0, -60px);transform: translate(0, -60px);}
    .about-support-block.support-block .support-block-list__item {width: calc(50% - var(--grid-desktop-horizontal-spacing) * 1 / 4);max-width: calc(50% - var(--grid-desktop-horizontal-spacing) * 1 / 3);}
  }
  
  @media screen and (max-width: 749px){
  .about-support-block.support-block .grid--peek.slider .grid__item:first-of-type {margin-left:0; }
  .about-support-block.support-block .grid--peek.slider .grid__item:last-of-type {margin-right: 0;}   
  }
 @media screen and (max-width: 576px) {
  .about-support-block.support-block .text-wrapper{justify-content: flex-start;width: 100%;transform: translate(0, -80px);-webkit-transform: translate(0, -80px);margin:0;}
  .about-support-block.support-block .text-wrapper a {font-size: 16px;}
  .about-support-block.support-block .image-wrapper .images img:last-child{-webkit-transform: translate(100px, 40px);transform: translate(100px, 40px);}
     
 }
  @media screen and (max-width: 480px) {
    .about-support-block.support-block .support-block-list__item {width: 100%;max-width: 100%;}
    .about-support-block.support-block .text-wrapper a {font-size: 14px;}
  }

  
{%- endstyle -%}
 

{%- liquid
  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign show_mobile_slider = false
  if section.settings.swipe_on_mobile and section.blocks.size > columns_mobile_int
    assign show_mobile_slider = true
  endif
  if section.settings.swiper_enable
  assign enable_slider = true  
  endif
-%}

<div class="support-block {{ section.settings.custom_class_name }} color-{{ section.settings.color_scheme }} gradient{% unless section.settings.background_style == 'none' and settings.text_boxes_border_thickness > 0 or settings.text_boxes_shadow_opacity > 0 %} background-{{ section.settings.background_style }}{% endunless %}{% if section.settings.title == blank %} no-heading{% endif %} section-{{ section.id }}">
  <div class="{% if section.settings.page_full_width %} page-full-width {% else %} page-width {% endif %} {% if section.settings.page_full_width_spacing %} page-full-width_spacing {% endif %}section-{{ section.id }}-padding isolate">
    <div class="row">
      {% if section.settings.sec_image_01 != blank %}  <div class="support-wrapper"> {% endif %}
    {%- unless section.settings.title == blank -%}
      <div class="title-wrapper-with-link title-wrapper--self-padded-mobile title-wrapper--no-top-margin content-align--{{ section.settings.column_alignment }}">
         {%- if section.settings.sub_heading != blank -%}  
         <h6 class="sub-heading">{{ section.settings.sub_heading | escape }}</h6>
         {%- endif -%} 
         {%- if section.settings.title != blank -%}  
          <h2 class="title {{ section.settings.heading_size }}">
            {{ section.settings.title | escape }}
          </h2>
          {%- endif -%} 
          {%- if section.settings.description != blank -%}  
          <p class="description">{{ section.settings.description }}</p>
          {%- endif -%}   
          {%- if section.settings.button_label != blank -%}
            <a {% if section.settings.button_link == blank %} role="link" aria-disabled="true"{% else %} href="{{ section.settings.button_link }}"{% endif %} class="button{% if section.settings.button_style_secondary %} button--secondary{% else %} button--primary{% endif %}">{{ section.settings.button_label | escape }}</a>
          {%- endif -%}
          </div>
    {%- endunless -%}

    {% unless enable_slider %}
    <slider-component class="slider-mobile-gutter">
      {% else %}
    <support-slider>
      <div data-slider-options='{"loop": "true","desktop": "{{ section.settings.desktop_column }}", "laptop": "{{ section.settings.laptop_column }}", "tablet": "{{ section.settings.tablet_column }}","mobile": "{{ section.settings.mobile_column }}","auto_play": "{{ section.settings.auto_play }}"}'>
      <div class="swiper" data-swiper-slider>
      {%- endunless -%}
        <ul id="Slider-{{ section.id }}"
          class="support-block-list contains-content-container slider {% if enable_slider %} swiper-wrapper{% else %} grid grid--peek grid--{{ section.settings.columns_mobile }}-col-tablet-down  grid--{{ section.settings.columns_desktop }}-col-desktop {% if show_mobile_slider or show_desktop_slider %} slider{% if show_desktop_slider %} slider--tablet-up{% endif %}{% if show_mobile_slider %} slider--mobile grid--peek{% endif %}{% endif %}{% endif %}"
          role="list"
        >
        
        {%- for block in section.blocks -%}
          {%- assign empty_column = '' -%}
          {%- if block.settings.image == blank and block.settings.title == blank and block.settings.text == blank and block.settings.link_label == blank -%}
            {%- assign empty_column = ' support-block-list__item--empty' -%}
          {%- endif -%}

          <li id="Slide-{{ section.id }}-{{ forloop.index }}" class="support-block-list__item {% if enable_slider %} swiper-slide{% else %} grid__item{% if section.settings.swipe_on_mobile %} slider__slide{% endif %} {% endif %}{% if section.settings.block_column_alignment == 'center' %} center{% endif %}{{ empty_column }} {{ section.settings.block_style }} " {{ block.shopify_attributes }}>
            <div class="support-block-card content-container {{ section.settings.vertical_position }}">
           
                <div class="support-block-card__image-wrapper {{ section.settings.image_ratio }} color-{{ section.settings.block_color_scheme }} gradient ">
              {%- if block.settings.image != blank -%}
                    {%- capture sizes -%}(min-width: 990px) {% if section.blocks.size <= 2 %}710px{% else %}550px{% endif %}, (min-width: 750px) {% if section.blocks.size == 1 %}710px{% else %}550px{% endif %}, calc(100vw - 30px){%- endcapture -%}
                    {{ block.settings.image | image_url: width: 275 | image_tag:
                      loading: 'lazy',
                      width: section.settings.image.width,
                      height: section.settings.image.height,
                      sizes: sizes,
                      widths: '275, 550, 710, 1420',
                      class: 'support-block-card__image',
                       alt: section.settings.image.alt | escape
                    }} 
                 {%- elsif  block.settings.icon_class != blank -%}
                 {{ block.settings.icon_class }}
                {%- endif -%}
                </div>              
              <div class="support-block-card__info">
                {%- if block.settings.title != blank -%}
                  <h3>{{ block.settings.title | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <div class="rte">{{ block.settings.text }}</div>
                {%- endif -%}
                {%- if block.settings.link_label != blank -%}
                  <a class="link animate-arrow" {% if block.settings.link == blank %}role="link" aria-disabled="true"{% else %}href="{{ block.settings.link }}"{% endif %}>{{ block.settings.link_label | escape }}<span class="icon-wrap">&nbsp;{% render 'icon-arrow' %}</span></a>
                {%- endif -%}
              </div>
            </div>
          </li>
        {%- endfor -%}
                </ul>
        
      {% unless enable_slider %}
      {%- if show_mobile_slider -%}
        {% if section.settings.arrow_on_mobile %}
        <div class="slider-buttons no-js-hidden medium-hide">
          <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="{{ 'general.slider.previous_slide' | t }}">{% render 'icon-caret' %}</button>
          <div class="slider-counter caption">
            <span class="slider-counter--current">1</span>
            <span aria-hidden="true"> / </span>
            <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
            <span class="slider-counter--total">{{ section.blocks.size }}</span>
          </div>
          <button type="button" class="slider-button slider-button--next" name="next" aria-label="{{ 'general.slider.next_slide' | t }}">{% render 'icon-caret' %}</button>
        </div>
      {%- endif -%}
      {%- endif -%}  
    </slider-component>
        {% else %}
        {% if section.settings.swiper_navigation != blank %}
        <div class="swiper-button-next"><span></span></div>
        <div class="swiper-button-prev"><span></span></div>
        {% endif %}
    </div>
    {% if section.settings.swiper_pagination != blank %}
    <div class="swiper-pagination"></div>
    {% endif %}
    </div>
    </support-slider>
    {%- endunless -%}
<!--     <div class="center{% if show_mobile_slider %} small-hide medium-hide{% endif %}">
      {%- if section.settings.button_label != blank -%}
        <a class="button button--primary"{% if section.settings.button_link == blank %} role="link" aria-disabled="true"{% else %} href="{{ section.settings.button_link }}"{% endif %}>
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
    </div> -->
    {% if section.settings.sec_image_01 != blank %}  </div> {% endif %}
    {% if section.settings.sec_image_01 != blank %}  
      <div class="image-wrapper">
        <div class="images">
          {% if section.settings.sec_image_01 != blank %}
            <img
                      class="banner-image"
                      srcset="{%- if section.settings.sec_image_01.width >= 375 -%}{{ section.settings.sec_image_01 | image_url: width: 375 }} 375w,{%- endif -%}
                      {%- if section.settings.sec_image_01.width >= 550 -%}{{ section.settings.sec_image_01 | image_url: width: 550 }} 550w,{%- endif -%}
                      {%- if section.settings.sec_image_01.width >= 750 -%}{{ section.settings.sec_image_01 | image_url: width: 750 }} 750w,{%- endif -%}
                      {%- if section.settings.sec_image_01.width >= 1100 -%}{{ section.settings.sec_image_01 | image_url: width: 1100 }} 1100w,{%- endif -%}
                      {%- if section.settings.sec_image_01.width >= 1500 -%}{{ section.settings.sec_image_01 | image_url: width: 1500 }} 1500w,{%- endif -%}
                      {%- if section.settings.sec_image_01.width >= 1780 -%}{{ section.settings.sec_image_01 | image_url: width: 1780 }} 1780w,{%- endif -%}
                      {%- if section.settings.sec_image_01.width >= 2000 -%}{{ section.settings.sec_image_01 | image_url: width: 2000 }} 2000w,{%- endif -%}
                      {%- if section.settings.sec_image_01.width >= 3000 -%}{{ section.settings.sec_image_01 | image_url: width: 3000 }} 3000w,{%- endif -%}
                      {%- if section.settings.sec_image_01.width >= 3840 -%}{{ section.settings.sec_image_01 | image_url: width: 3840 }} 3840w,{%- endif -%}
                      {{ section.settings.sec_image_01 | image_url: width: 1500 }} {{ section.settings.sec_image_01.width }}w"
                      sizes="100vw"
                      src="{{ section.settings.sec_image_01 | image_url: width: 1500 }}"
                      loading="lazy"              
                      alt="{{ section.settings.sec_image_01.alt | escape }}"
                      width="{{ section.settings.sec_image_01.width }}"
                      height="{{ section.settings.sec_image_01.width | divided_by: section.settings.sec_image_01.aspect_ratio | round }}"
                    >          
            {% endif %}
          {% if section.settings.sec_image_02 != blank %}
            <img
                      class="banner-image"
                      srcset="{%- if section.settings.sec_image_02.width >= 375 -%}{{ section.settings.sec_image_02 | image_url: width: 375 }} 375w,{%- endif -%}
                      {%- if section.settings.sec_image_02.width >= 550 -%}{{ section.settings.sec_image_02 | image_url: width: 550 }} 550w,{%- endif -%}
                      {%- if section.settings.sec_image_02.width >= 750 -%}{{ section.settings.sec_image_02 | image_url: width: 750 }} 750w,{%- endif -%}
                      {%- if section.settings.sec_image_02.width >= 1100 -%}{{ section.settings.sec_image_02 | image_url: width: 1100 }} 1100w,{%- endif -%}
                      {%- if section.settings.sec_image_02.width >= 1500 -%}{{ section.settings.sec_image_02 | image_url: width: 1500 }} 1500w,{%- endif -%}
                      {%- if section.settings.sec_image_02.width >= 1780 -%}{{ section.settings.sec_image_02 | image_url: width: 1780 }} 1780w,{%- endif -%}
                      {%- if section.settings.sec_image_02.width >= 2000 -%}{{ section.settings.sec_image_02 | image_url: width: 2000 }} 2000w,{%- endif -%}
                      {%- if section.settings.sec_image_02.width >= 3000 -%}{{ section.settings.sec_image_02 | image_url: width: 3000 }} 3000w,{%- endif -%}
                      {%- if section.settings.sec_image_02.width >= 3840 -%}{{ section.settings.sec_image_02 | image_url: width: 3840 }} 3840w,{%- endif -%}
                      {{ section.settings.sec_image_02 | image_url: width: 1500 }} {{ section.settings.sec_image_02.width }}w"
                      sizes="100vw"
                      src="{{ section.settings.sec_image_02 | image_url: width: 1500 }}"
                      loading="lazy"              
                      alt="{{ section.settings.sec_image_02.alt | escape }}"
                      width="{{ section.settings.sec_image_02.width }}"
                      height="{{ section.settings.sec_image_02.width | divided_by: section.settings.sec_image_02.aspect_ratio | round }}"
                    >          
            {% endif %}
        </div>
      <div class="text-wrapper">
        {% if section.settings.text_heading %}
        <h6 class="text">{{ section.settings.text_heading }}</h6>
         {% endif %} 
        {% if section.settings.phone_no %}
        <a href="tel:{{ section.settings.phone_no }}" class="link">{{ section.settings.phone_no }}</a>
        {% endif %}
      </div>
      </div>
      {% endif %}
      </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.support-block.name",
  "class": "section",
  "tag": "section",
  "settings": [
    {
      "type":"checkbox",
      "id":"page_full_width",
       "default": false,
      "label": "t:sections.all.page_full_width.label"
    },
    {
      "type":"checkbox",
      "id":"page_full_width_spacing",
       "default": false,
      "label": "t:sections.all.page_full_width_spacing.label"
    },
    {
      "type":"image_picker",
      "id": "bg_image",
      "label": "t:sections.support-block.settings.bg_image.label"
    },
    {
      "type": "text",
      "id": "title",
      "default": "Support Block",
      "label": "t:sections.all.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "text",
      "id": "sub_heading",
      "label": "t:sections.all.sub_heading.label"
    },
     {
      "type": "text",
      "id": "description",
      "label": "t:sections.all.description.label"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "Button label",
      "label": "t:sections.all.button_label.label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.all.button_link.label"
    },
    {
      "type": "checkbox",
      "id": "button_style_secondary",
      "default": false,
      "label": "t:sections.all.button_style_secondary.label"
      },
    {
      "type": "select",
      "id": "column_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:sections.support-block.settings.column_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.support-block.settings.column_alignment.options__2.label"
        }
      ],
      "default": "left",
      "label": "t:sections.support-block.settings.column_alignment.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "t:sections.support-block.settings.columns_desktop.label"
    },
    {
      "type": "select",
      "id": "background_style",
      "options": [
        {
          "value": "none",
          "label": "t:sections.support-block.settings.background_style.options__1.label"
        },
        {
          "value": "primary",
          "label": "t:sections.support-block.settings.background_style.options__2.label"
        }
      ],
      "default": "primary",
      "label": "t:sections.support-block.settings.background_style.label"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "accent-1",
          "label": "t:sections.all.colors.accent_1.label"
        },
        {
          "value": "accent-2",
          "label": "t:sections.all.colors.accent_2.label"
        },
        {
          "value": "background-1",
          "label": "t:sections.all.colors.background_1.label"
        },
        {
          "value": "background-2",
          "label": "t:sections.all.colors.background_2.label"
        },
        {
          "value": "inverse",
          "label": "t:sections.all.colors.inverse.label"
        }
      ],
      "default": "background-1",
      "label": "t:sections.all.colors.label"
    },
    {
      "type": "header",
      "content": "t:sections.support-block.settings.block_settings.content"
    },
     {
      "type": "select",
      "id": "block_style",
      "options": [
